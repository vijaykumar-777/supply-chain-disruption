ATLAS_ENV=development
ATLAS_MODE=live

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

OPENWEATHERMAP_API_KEY=
NOMINATIM_USER_AGENT=reliefroute-karnataka/1.0

# Official/live disaster feeds. Leave blank until you get access.
IMD_API_KEY=
IMD_ALERT_FEED_URL=

KSNDMC_API_KEY=
KSNDMC_RAINFALL_FEED_URL=

KSDMA_API_KEY=
KSDMA_BULLETIN_FEED_URL=

CWC_API_KEY=
CWC_FLOODWATCH_FEED_URL=

# Optional backup news search when GDELT is rate-limited.
NEWSAPI_KEY=
NEWSAPI_BASE_URL=https://newsapi.org/v2/everything

# Additional Karnataka news sources. Enable the free/free-tier providers you choose.
NEWSDATA_API_KEY=
NEWSDATA_BASE_URL=https://newsdata.io/api/1/latest

THENEWSAPI_TOKEN=
THENEWSAPI_BASE_URL=https://api.thenewsapi.com/v1/news/all

MEDIASTACK_API_KEY=
MEDIASTACK_BASE_URL=https://api.mediastack.com/v1/news

GNEWS_API_KEY=
GNEWS_BASE_URL=https://gnews.io/api/v4/search

WORLDNEWSAPI_KEY=
WORLDNEWSAPI_BASE_URL=https://api.worldnewsapi.com/search-news

FREENEWSAPI_KEY=
FREENEWSAPI_BASE_URL=https://api.freenewsapi.io/v1/news

GUARDIAN_API_KEY=
GUARDIAN_BASE_URL=https://content.guardianapis.com/search

# No-key RSS/search feeds. Set to false if they become noisy or rate-limited.
GOOGLE_NEWS_RSS_ENABLED=true
BING_NEWS_RSS_ENABLED=true
PIB_RSS_URL=https://pib.gov.in/RssMain.aspx?ModId=6&Lang=1&Regid=6
NEWS_LOOKBACK_DAYS=30

# Optional routing/map providers.
OSRM_BASE_URL=
MAPBOX_API_KEY=

OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2
